# Copy to .env for local implementation runs.
# Demo must work with DEMO_MODE=true and no MISTRAL_API_KEY.

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_COMPRESSOR_MODEL=mistral-small-latest
MISTRAL_OBSERVER_MODEL=ministral-8b-latest

# true = never call live API; use template/fixture compress only
DEMO_MODE=false

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Mistral Vibe → Glass Box hook adapter. Copy only the token value into your
# local .env; never commit it. The defaults point to a local Glass Box server.
GLASSBOX_VIBE_EVENTS_URL=http://127.0.0.1:8000/api/v1/vibe/events
GLASSBOX_VIBE_CONTROL_URL_TEMPLATE=http://127.0.0.1:8000/api/v1/runs/{run_id}/control
GLASSBOX_VIBE_TOKEN=
GLASSBOX_VIBE_RUN_ID=
GLASSBOX_VIBE_TIMEOUT_SECONDS=1.5
